---
// src/components/Hero.astro
---

<section
    class="relative w-full h-screen flex flex-col items-center justify-center bg-waza-black overflow-hidden"
>
    <div class="absolute inset-0 w-full h-full z-0">
        <img
            src="/images/hero-sushi.jpg"
            alt="REN WAZA Background"
            class="w-full h-full object-cover opacity-35 filter brightness-75 contrast-125"
        />
        <div
            class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-waza-black to-transparent"
        >
        </div>
        <div
            class="absolute inset-x-0 bottom-0 h-52 bg-gradient-to-t from-waza-black to-transparent"
        >
        </div>
    </div>

    <div class="relative z-10 text-center px-4 space-y-8 max-w-2xl">
        <div class="space-y-3">
            <h1
                class="font-serif-display text-7xl md:text-9xl uppercase tracking-tighter text-waza-white"
            >
                REN
            </h1>
            <p
                class="font-mon-cheri text-waza-red text-sm md:text-base tracking-waza-wide uppercase"
            >
                WAZA
            </p>
        </div>

        <p
            class="text-waza-white/70 font-sans text-xs md:text-sm tracking-[0.2em] uppercase max-w-md mx-auto leading-relaxed"
        >
            Handmade Sushi Experience <span class="text-waza-red mx-1">//</span> Porto
        </p>

        <div class="pt-4">
            <a
                href="#reserva"
                class="inline-block border border-waza-white/30 text-waza-white hover:border-waza-red hover:bg-waza-red font-sans text-xs tracking-widest uppercase py-3.5 px-9 transition-all duration-300 rounded-sm bg-waza-black/40 backdrop-blur-sm"
            >
                Solicitar Experiência
            </a>
        </div>
    </div>

    <div
        class="absolute bottom-6 left-1/2 transform -translate-x-1/2 z-10 opacity-30 animate-bounce"
    >
        <span
            class="font-sans text-[10px] tracking-widest uppercase text-waza-white"
            >Scroll</span
        >
    </div>
</section>
