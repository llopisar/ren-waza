---
// src/layouts/Layout.astro
interface Props {
    title: string;
}

const { title } = Astro.props;

// 🔌 LA CONEXIÓN MÁGICA: Importamos el archivo de estilos directamente aquí
import "../styles/global.css";
---

<!doctype html>
<html lang="pt">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="bg-waza-black min-h-screen antialiased">
        <slot />
    </body>
</html>
