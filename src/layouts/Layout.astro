---
// src/layouts/Layout.astro
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="description"
            content="REN WAZA - Handmade Sushi Experience em Porto. Omakase privado e o culto à técnica artesanal japonesa."
        />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <!-- Fuentes de Google: Noto Serif Display -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Noto+Serif+Display:ital,wght@0,100..900;1,100..900&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="bg-waza-black text-waza-white antialiased selection:bg-waza-red selection:text-white"
    >
        <!-- El Slot es donde se va a inyectar el contenido de tu index.astro -->
        <slot />
    </body>
</html>
